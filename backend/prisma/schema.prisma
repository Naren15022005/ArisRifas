generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["clientExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl is used by Prisma for migration commands (direct DB connection)
  // when using Supabase with a transaction pooler set in DATABASE_URL (pgbouncer),
  // set DIRECT_URL to the direct Postgres connection (port 5432) and Prisma will
  // use it for migrations while using DATABASE_URL at runtime.
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  name      String
  phone     String?
  role      Role       @default(CUSTOMER)
  password  String
  createdAt DateTime   @default(now())
  purchases Purchase[]
}

model Raffle {
  id                Int        @id @default(autoincrement())
  title             String
  description       String?    @db.Text
  imageUrl          String?
  pricePerTicket    Decimal    @db.Decimal(10, 2)
  totalTickets      Int
  drawDate          DateTime
  isPublished       Boolean    @default(false)
  createdAt         DateTime   @default(now())
  estimatedValue    Decimal?   @db.Decimal(10, 2)
  associatedLottery String?    @db.VarChar(255)
  purchases         Purchase[]
  tickets           Ticket[]
}

model Ticket {
  id            Int           @id @default(autoincrement())
  raffleId      Int
  number        Int
  status        TicketStatus  @default(AVAILABLE)
  reservedUntil DateTime?
  createdAt     DateTime      @default(now())
  purchaseItem  PurchaseItem?
  raffle        Raffle        @relation(fields: [raffleId], references: [id])

  @@unique([raffleId, number])
  @@index([raffleId, status])
}

model Purchase {
  id        Int            @id @default(autoincrement())
  userId    Int
  raffleId  Int
  total     Decimal        @db.Decimal(10, 2)
  status    PurchaseStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  payment   Payment?
  raffle    Raffle         @relation(fields: [raffleId], references: [id])
  user      User           @relation(fields: [userId], references: [id])
  items     PurchaseItem[]

  @@index([raffleId])
  @@index([userId])
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  ticketId   Int      @unique
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  ticket     Ticket   @relation(fields: [ticketId], references: [id])

  @@unique([purchaseId, ticketId])
}

model Payment {
  id             Int           @id @default(autoincrement())
  purchaseId     Int           @unique
  wompiReference String        @unique
  amount         Decimal       @db.Decimal(10, 2)
  status         PaymentStatus @default(PENDING)
  wompiStatus    String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  purchase       Purchase      @relation(fields: [purchaseId], references: [id])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  entity    String
  entityId  Int?
  action    String
  payload   String?  @db.Text
  createdAt DateTime @default(now())
}

model IdempotencyKey {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  purchaseId Int?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

enum Role {
  ADMIN
  CUSTOMER
}

enum TicketStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum PurchaseStatus {
  PENDING
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  APPROVED
  DECLINED
  VOIDED
  ERROR
}
