# Example environment variables for local development
# Copy to .env and fill values (do NOT commit secrets)

# Application
PORT=3001

# Prisma (Postgres connection string)
# Example: postgresql://aris_user:ENCODED_PASSWORD@gvbhwgpjqzbflcjhdqx.supabase.co:5432/postgres
DATABASE_URL=

# Supabase storage and keys
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_UPLOAD_BUCKET=uploads

# Frontend origins
FRONTEND_ORIGINS=http://localhost:3000

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
# Example env for backend
DATABASE_URL="mysql://user:password@host:3306/database"
JWT_SECRET="replace_me"
NODE_ENV=production
FRONTEND_ORIGINS="https://aris-rifas.vercel.app"
