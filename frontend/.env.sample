# Ejemplo de variables de entorno para frontend
# Copia este archivo a .env.local en tu entorno local (no lo subas a git)

# URL base de las Supabase Edge Functions (sin barra final)
# Recomendado: https://<tu-proyecto>.supabase.co/functions/v1
NEXT_PUBLIC_BACKEND_URL=

# URL pública del proyecto Supabase (sin barra final)
NEXT_PUBLIC_SUPABASE_URL=

# Nombre del bucket público donde subirás archivos (ej: "public" o "uploads")
NEXT_PUBLIC_SUPABASE_UPLOAD_BUCKET=uploads

# Clave pública (anon) de Supabase para uso en el cliente (opcional si sólo lees archivos públicos)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# API fallback (si usas un backend tradicional en vez de funciones)
NEXT_PUBLIC_API_URL=

# Notas:
# - Añade estas mismas variables en Vercel (Settings → Environment Variables) usando los mismos nombres.
# - Para Production define los valores en Environment=Production y Preview si quieres probar en previews.
# - Después de cambiarlas, fuerza un redeploy en Vercel para que entren en vigor.
